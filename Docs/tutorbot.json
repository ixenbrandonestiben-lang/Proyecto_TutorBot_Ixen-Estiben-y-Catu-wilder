              "filtersUI": {
                "values": [
                  {
                    "lookupColumn": "dia_semana",
                    "lookupValue": "={{ $json.dia_semana }}"
                  },
                  {
                    "lookupColumn": "estado",
                    "lookupValue": "Libre"
                  }
                ]
              },
              "options": {}
            },
