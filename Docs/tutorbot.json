    {
      "parameters": {
        "jsCode": "/* Construir teclado de materias desde la hoja tutores (normaliza callback_data)\n   Entrada: salida de Get Tutores\n   Salida: { chat_id, text, inline_keyboard }\n*/\nconst rows = $input.all().map(i => i.json);\n// extraer materias únicas\nconst materiasSet = new Set();\nrows.forEach(r => {\n  const list = (r.especialidad_materias || '').split(',').map(x=>x.trim()).filter(Boolean);\n  list.forEach(m => materiasSet.add(m));\n});\nconst materias = Array.from(materiasSet);\nfunction slug(s){\n  return s.toString().normalize('NFKD').replace(/[\u0300-\\u036f]/g,'').replace(/[^a-zA-Z0-9 _-]/g,'').trim().replace(/\\s+/g,'_').slice(0,64);\n}\nconst keyboard = materias.map(m => [{ text: m, callback_data: 'MAT_' + slug(m) }]);\n// chat_id will be provided by Telegram Trigger (user chat id) from 'Preparar Datos' in the run; if not, we expect the caller to replace it.\nconst chatId = $('Telegram Trigger').first() ? $('Telegram Trigger').item.json.message.chat.id : null;\nreturn [{ json: { chat_id: chatId, text: 'Selecciona la materia:', reply_markup: { inline_keyboard: keyboard } } }];",
        "id": "node-build-materias",
        "name": "Construir Teclado Materias",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -400,
          -400
        ]
      },
      {
        "parameters": {
          "chatId": "={{ $json.chat_id }}",
          "text": "={{ $json.text }}",
          "replyMarkup": "inlineKeyboard",
          "inlineKeyboard": {
            "rows": "={{ $json.reply_markup.inline_keyboard.map(r => ({ row: { buttons: r.map(b => ({ text: b.text, additionalFields: { callback_data: b.callback_data } })) } })) }}"
          },
          "additionalFields": {}
        },
        {
          "id": "node-send-materias",
          "name": "Enviar Teclado Materias",
          "type": "n8n-nodes-base.telegram",
          "typeVersion": 1.2,
          "position": [
            0,
            -400
          ],
          "credentials": {
            "telegramApi": {
              "name": "Telegram account"
            }
          }
        },
        {
          "parameters": {
            "jsCode": "/* Validar Fecha YYYY-MM-DD y calcular dia_semana (America/Guatemala) */\nconst j = $input.first().json;\nconst texto = (j.entrada || j.message_text || '').trim();\nconst regex = /^\\\\d{4}-\\\\d{2}-\\\\d{2}$/;\nconst fechaValida = regex.test(texto) && !isNaN(Date.parse(texto + 'T00:00:00'));\nconst moment = require('moment-timezone');\nconst tz = 'America/Guatemala';\nlet dia_semana = '';\nif (fechaValida) {\n  const d = moment.tz(texto, 'YYYY-MM-DD', tz);\n  dia_semana = d.format('dddd');\n}\nreturn [{ json: { fecha: texto, fechaValida, dia_semana, telegram_user: j.telegram_user || (j.message && j.message.from && j.message.from.username) || (j.message && j.message.chat && j.message.chat.id) } }];",
            "id": "node-validar-fecha",
            "name": "Validar Fecha",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
              -400,
              0
            ]
          },
          {
            "parameters": {
              "operation": "getAll",
              "documentId": "1RTZiuOpuPfLvGUFarwTBgEM1qIZuySJh6iHOSdvnE9E",
