          {
            "parameters": {
              "jsCode": "/* Enviar notificación al tutor con botones Confirmar/Rechazar */\nconst parsed = $('Parsear Sugerencia IA').first().json.parsed;\n// buscar telegram_user del tutor en hoja tutores: idealmente usar nodo 'Get Tutores' con filtro id_tutor\nconst tutorChat = null; // placeholder: este valor debe ser obtenido con un GoogleSheets lookup por id_tutor\nconst reserva_id = $now.format('X') + '_' + Math.floor(Math.random()*1000);\nconst text = `Nueva tutoria asignada: Materia: ${$('Validar Fecha').first().json.materia || ''}\\nFecha: ${$('Validar Fecha').first().json.fecha} ${parsed.hora_inicio}\\nEstudiante: ${$json.id_estudiante || $json.telegram_user || ''}`;\nconst keyboard = [\n  [{ text: 'Confirmar', callback_data: `TCONF_${reserva_id}_yes` }],\n  [{ text: 'Rechazar', callback_data: `TCONF_${reserva_id}_no` }]\n];\n// Emitir: este nodo debe conectar a un Telegram node para enviar a tutorChat. Si tutorChat es null, el flujo enviará al admin.\nreturn [{ json: { chat_id: tutorChat, text, reply_markup: { inline_keyboard: keyboard }, reserva_id } }];",
              "id": "node-notificar-tutor-code",
