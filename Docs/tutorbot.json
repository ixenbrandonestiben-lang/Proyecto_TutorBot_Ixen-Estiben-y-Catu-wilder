          {
            "parameters": {
              "jsCode": "/* double_check_before_confirm: re-lee disponibilidad y confirma estado 'Pendiente' por mismo usuario */\nconst rowNumber = $input.first().json.row_number_disp;\nif(!rowNumber) throw new Error('row_number_disp missing');\n// En n8n: este nodo debe recibir la salida del GoogleSheets lookup que obtiene la fila exacta.\n// Aquí asumimos que el nodo anterior 'Buscar por row_number' devolvió la fila en $items()\nconst dispo = $input.first().json.disponibilidad || $input.first().json; // adaptarse al output real\nif(!dispo) return [{ json: { ok:false, reason:'Disponibilidad no encontrada' } }];\nif(dispo.estado !== 'Pendiente') return [{ json: { ok:false, reason:'Slot no pendiente' } }];\nif(dispo.pending_by != ($input.first().json.telegram_user)) return [{ json: { ok:false, reason:'Slot reservado por otro usuario' } }];\n// ok\nreturn [{ json: { ok:true, dispo } }];",
              "id": "node-double-check",
              "name": "Double Check Before Confirm (Code)",
              "type": "n8n-nodes-base.code",
              "typeVersion": 2,
