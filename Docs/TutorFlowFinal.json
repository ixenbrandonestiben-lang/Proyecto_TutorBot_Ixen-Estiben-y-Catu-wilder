      "parameters": {
        "jsCode": "const prep = $('Preparar Datos').first().json;\nconst rows = $input.all().map(i => i.json);\nlet texto = 'No tienes tutorias registradas.';\nif (rows.length) {\n  texto = rows.map(r => `Materia: ${r.materia}\\nFecha: ${r.fecha} ${r.hora}\\nEstado: ${r.estado}`).join('\\n\\n');\n}\nreturn [{ json: { chat_id: prep.chat_id, texto } }];"
      },
