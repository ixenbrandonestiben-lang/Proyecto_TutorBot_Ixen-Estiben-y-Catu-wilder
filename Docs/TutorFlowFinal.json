      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst materias = [...new Set(rows.flatMap(r => (r.especialidad_materias||'').split(',').map(m => m.trim()).filter(Boolean)))];\nconst keyboard = materias.map(m => [{ text: m, callback_data: 'MAT_' + m }]);\nconst prep = $('Preparar Datos').first().json;\nreturn [{ json: { chat_id: prep.chat_id, keyboard } }];"
      },
