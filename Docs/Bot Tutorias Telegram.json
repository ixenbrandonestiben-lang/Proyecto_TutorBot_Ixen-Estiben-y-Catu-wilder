    {
      "parameters": {
        "jsCode": "const tutores = $('Buscar Tutores').all();\nconst disponibilidad = $('Buscar Disponibilidad').all();\n\nlet mensaje = 'Tutores disponibles:\\n\\n';\n\nif (tutores.length === 0) {\n  mensaje = 'No hay tutores disponibles para esa materia.';\n} else {\n  tutores.forEach((t, idx) => {\n    const dispo = disponibilidad.filter(d => d.json.id_tutor === t.json.id_tutor);\n    mensaje += `${idx + 1}. ${t.json.nombre}\\n`;\n    mensaje += `   Materia: ${t.json.especialidad_materias}\\n`;\n    if (dispo.length > 0) {\n      dispo.forEach(d => {\n        mensaje += `   ${d.json.dia_semana} ${d.json.hora_inicio} - ${d.json.hora_fin}\\n`;\n      });\n    } else {\n      mensaje += `   Sin disponibilidad registrada\\n`;\n    }\n    mensaje += '\\n';\n  });\n}\n\nreturn [{ json: { mensaje } }];"
      },
